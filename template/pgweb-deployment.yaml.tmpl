# Web SQL console (pgweb) for a tool's bundled Postgres. Read-WRITE. NON-PHI only.
# Reachable over Tailscale; connects via the tool's existing {{NAME}}-db secret (the bot
# never sees the credential — K8s injects it at runtime).
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{NAME}}-dbconsole
  namespace: {{NAMESPACE}}
  labels:
    app: {{NAME}}-dbconsole
    qh-tool/name: {{NAME}}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{NAME}}-dbconsole
  template:
    metadata:
      labels:
        app: {{NAME}}-dbconsole
    spec:
      containers:
        - name: pgweb
          image: sosedoff/pgweb:latest
          # The bundled Postgres has no SSL, but pgweb (lib/pq) defaults to sslmode=require.
          # Pass the URL explicitly with sslmode=disable. DB_URL (not DATABASE_URL) so pgweb
          # only uses the --url flag, not an auto-read env var.
          command: ["/bin/sh", "-c"]
          args:
            - 'exec pgweb --bind=0.0.0.0 --listen=8081 --url "$DB_URL?sslmode=disable"'
          env:
            - name: DB_URL
              valueFrom:
                secretKeyRef:
                  name: {{NAME}}-db
                  key: DATABASE_URL
          ports:
            - containerPort: 8081
