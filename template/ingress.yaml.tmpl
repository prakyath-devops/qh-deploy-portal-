apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{NAME}}
  namespace: {{NAMESPACE}}
  labels:
    qh-tool/name: {{NAME}}
  annotations:
    cert-manager.io/cluster-issuer: letsencrypt-dns01
spec:
  ingressClassName: nginx            # INTERNAL ingress (10.0.0.8), Tailscale-only
  tls:
    - hosts:
        - {{HOST}}
      secretName: {{NAME}}-tls
  rules:
    - host: {{HOST}}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{PUBLIC_SVC}}
                port:
                  number: {{PUBLIC_PORT}}
